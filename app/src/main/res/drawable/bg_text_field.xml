<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Estado enfocado  -->
    <item android:state_focused="true">
        <shape>
            <solid android:color="@color/S2" />
            <corners android:radius="15dp" />
            <stroke
                android:width="2dp"
                android:color="@color/LCBlue" />
            <padding
                android:left="12dp"
                android:right="12dp"
                android:top="12dp"
                android:bottom="12dp" />
        </shape>
    </item>

    <!-- Estado sin enfocar -->
    <item>
        <shape>
            <solid android:color="@color/S2" />
            <corners android:radius="15dp" />
            <stroke
                android:width="1dp"
                android:color="@color/S3" />
            <padding
                android:left="12dp"
                android:right="12dp"
                android:top="12dp"
                android:bottom="12dp" />
        </shape>
    </item>
</selector>