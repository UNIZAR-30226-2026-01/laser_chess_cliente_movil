<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#80000000">

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="24dp"
        android:layout_gravity="center"
        android:backgroundTint="@android:color/white"
        app:cardCornerRadius="20dp"
        app:cardElevation="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:gravity="center_horizontal">

            <TextView
                android:id="@+id/textWaitingTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Buscando partida"
                android:textSize="24sp"
                android:textStyle="bold"
                android:layout_marginBottom="20dp" />

            <ProgressBar
                android:id="@+id/progressWaitingMatch"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp" />

            <TextView
                android:id="@+id/textWaitingOpponent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Esperando a que el rival acepte la partida"
                android:textSize="16sp"
                android:gravity="center"
                android:layout_marginBottom="10dp" />

            <TextView
                android:id="@+id/textWaitingDetails"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tablero 1 · 300s + 10s"
                android:textSize="14sp"
                android:gravity="center"
                android:layout_marginBottom="24dp" />

            <Button
                android:id="@+id/buttonCancelMatchRequest"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cancelar" />

        </LinearLayout>

    </androidx.cardview.widget.CardView>

</FrameLayout>