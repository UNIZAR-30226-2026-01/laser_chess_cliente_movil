<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_modal_border"
        android:padding="24dp">

        <!-- Cerrar -->
        <ImageButton
            android:id="@+id/buttonCloseRequestsDialog"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_gravity="start"
            android:background="@drawable/bg_box_border"
            android:src="@drawable/ic_close"
            android:contentDescription="@string/close"
            android:padding="8dp"
            android:layout_marginBottom="12dp" />

        <TextView
            android:id="@+id/textRequestsDialogTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/requests"
            android:textStyle="bold"
            android:textSize="25sp"
            android:textColor="@android:color/black"
            android:layout_marginBottom="20dp" />

        <!-- Recibidas -->
        <TextView
            android:id="@+id/textReceivedRequestsTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/received_requests"
            android:textStyle="bold"
            android:textSize="20sp"
            android:textColor="@android:color/black"
            android:layout_marginBottom="10dp" />

        <TextView
            android:id="@+id/textEmptyReceivedRequests"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/no_received_requests"
            android:textSize="15sp"
            android:textColor="@color/darker_gray"
            android:visibility="gone"
            android:layout_marginBottom="10dp" />

        <LinearLayout
            android:id="@+id/layoutReceivedRequestsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="20dp" />

        <!-- Separador -->
        <View
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:background="@android:color/black"
            android:layout_marginBottom="20dp" />

        <!-- Enviadas -->
        <TextView
            android:id="@+id/textSentRequestsTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/sent_requests"
            android:textStyle="bold"
            android:textSize="20sp"
            android:textColor="@android:color/black"
            android:layout_marginBottom="10dp" />

        <TextView
            android:id="@+id/textEmptySentRequests"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/no_sent_requests"
            android:textSize="15sp"
            android:textColor="@color/darker_gray"
            android:visibility="gone"
            android:layout_marginBottom="10dp" />

        <LinearLayout
            android:id="@+id/layoutSentRequestsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

    </LinearLayout>
</FrameLayout>