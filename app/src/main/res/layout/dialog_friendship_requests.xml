<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_modal_border"
        android:padding="24dp">

        <!-- Cerrar -->
        <ImageButton
            android:id="@+id/buttonCloseRequestsDialog"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_gravity="start"
            android:background="@drawable/bg_box_border"
            android:src="@drawable/ic_close"
            android:contentDescription="@string/close"
            android:padding="8dp"
            android:layout_marginBottom="12dp" />

        <TextView
            android:id="@+id/textRequestsDialogTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/requests"
            android:textStyle="bold"
            android:textSize="25sp"
            android:textColor="@android:color/black"
            android:layout_marginBottom="20dp" />

        <!-- Tabs -->
        <LinearLayout
            android:id="@+id/layoutRequestTabs"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="20dp">

            <TextView
                android:id="@+id/tabReceivedRequests"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/bg_tab_selected"
                android:gravity="center"
                android:paddingVertical="10dp"
                android:text="@string/received_requests"
                android:textColor="@android:color/black"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tabSentRequests"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/bg_tab_unselected"
                android:gravity="center"
                android:paddingVertical="10dp"
                android:text="@string/sent_requests"
                android:textColor="@android:color/black"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Contenido RECIBIDAS -->
        <LinearLayout
            android:id="@+id/layoutReceivedRequestsContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/textEmptyReceivedRequests"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/no_received_requests"
                android:textSize="15sp"
                android:textColor="@color/darker_gray"
                android:visibility="gone"
                android:layout_marginBottom="10dp" />

            <LinearLayout
                android:id="@+id/layoutReceivedRequestsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />
        </LinearLayout>

        <!-- Contenido ENVIADAS -->
        <LinearLayout
            android:id="@+id/layoutSentRequestsContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:id="@+id/textEmptySentRequests"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/no_sent_requests"
                android:textSize="15sp"
                android:textColor="@color/darker_gray"
                android:visibility="gone"
                android:layout_marginBottom="10dp" />

            <LinearLayout
                android:id="@+id/layoutSentRequestsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />
        </LinearLayout>

    </LinearLayout>
</FrameLayout>