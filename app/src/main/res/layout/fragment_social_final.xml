<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:paddingHorizontal="24dp"
    android:paddingTop="16dp"
    android:paddingBottom="16dp">

    <LinearLayout
        android:id="@+id/layoutTabs"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:background="@drawable/bg_dark_panel"
        android:orientation="horizontal"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:id="@+id/tabSocial"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground">

            <TextView
                android:id="@+id/txtTabSocial"
                android:layout_width="wrap_content"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="SOCIAL"
                android:textColor="@color/LCWhite"
                android:textSize="@dimen/text_medium"
                android:textStyle="bold" />

            <View
                android:id="@+id/indicatorSocial"
                android:layout_width="match_parent"
                android:layout_height="4dp"
                android:background="#FF0044" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/tabMatches"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground">

            <TextView
                android:id="@+id/txtTabMatches"
                android:layout_width="wrap_content"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="PARTIDAS"
                android:textColor="#80FFFFFF"
                android:textSize="@dimen/text_medium"
                android:textStyle="bold" />

            <View
                android:id="@+id/indicatorMatches"
                android:layout_width="match_parent"
                android:layout_height="4dp"
                android:background="@android:color/transparent" />
        </LinearLayout>

    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerViewSocial"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/layoutTabs"
        app:layout_constraintBottom_toTopOf="@id/layoutBottomActions"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layoutBottomActions"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:id="@+id/groupSocialButtons"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <ImageButton
                android:id="@+id/btnSocialSecondary"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:layout_marginEnd="16dp"
                android:background="@drawable/bg_dark_panel"
                android:src="@drawable/ic_launcher_foreground"
                app:tint="#FF0044" />

            <Button
            android:id="@+id/btnAddFriend"
            android:layout_width="0dp"
            android:layout_height="64dp"
            android:layout_weight="1"
            android:backgroundTint="#FF0044"
            android:text="+  AÑADIR"
            android:textColor="@color/LCWhite"
            android:textSize="@dimen/text_large"
            android:textStyle="bold"
            app:cornerRadius="12dp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/groupMatchesButtons"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <Button
                android:id="@+id/btnInvitations"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:text="INVITACIONES"
                android:textColor="@color/LCWhite"
                android:textSize="@dimen/text_large"
                android:textStyle="bold"
                app:cornerRadius="12dp"
                app:strokeColor="#FF0044"
                app:strokeWidth="2dp" />
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>