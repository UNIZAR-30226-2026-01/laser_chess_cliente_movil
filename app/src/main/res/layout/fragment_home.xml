<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.HomeFragment">

    <ImageButton
        android:id="@+id/btnSettings"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:src="@drawable/ic_settings"
        android:contentDescription="@string/settings"
        android:scaleType="centerInside"
        android:padding="8dp"
        android:layout_marginStart="32dp"


        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/layoutTimeMode"
        app:layout_constraintStart_toStartOf="parent"
        />

    <LinearLayout
        android:id="@+id/layoutTimeMode"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="16dp"
        app:layout_constraintVertical_chainStyle="packed"

        app:layout_constraintTop_toBottomOf="@id/btnSettings"
        app:layout_constraintBottom_toTopOf="@id/boardSelection"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/cardElo"
        app:layout_constraintHorizontal_bias="0.6"
        >

        <ImageButton
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_timer"
            android:contentDescription="@string/timer"
            android:layout_marginEnd="8dp"
            android:scaleType="centerInside"
            android:padding="8dp"/>

        <TextView
            android:id="@+id/txtModoTiempo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/time_mode"
            android:textSize="18sp"
            android:textStyle="bold"/>

    </LinearLayout>

    <ImageButton
        android:id="@+id/boardSelection"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintWidth_percent="0.6"
        android:src="@drawable/ic_tablero_prov"
        android:contentDescription="@string/game_board"
        android:scaleType="fitCenter"
        app:layout_constraintHorizontal_chainStyle="packed"

        app:layout_constraintTop_toBottomOf="@id/layoutTimeMode"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/cardElo"
        app:layout_constraintBottom_toTopOf="@id/btnPlay"
        android:layout_marginBottom="30dp"
        android:layout_marginEnd="24dp"
        />

    <androidx.cardview.widget.CardView
        android:id="@+id/cardElo"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintWidth_percent="0.20"
        app:cardCornerRadius="16dp"
        app:cardElevation="4dp"

        app:layout_constraintTop_toTopOf="@id/btnSettings"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="@id/boardSelection"
        app:layout_constraintStart_toEndOf="@id/boardSelection">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/elo"
                android:layout_marginTop="8dp"
                android:textSize="12sp"
                android:textStyle="bold"/>

            <View
                android:layout_width="8dp"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:background="#CDCDCD"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:id="@+id/txtElo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1234"
                android:textStyle="bold"
                android:layout_marginTop="8dp"/>

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:contentDescription="@string/elo"
                android:src="@drawable/ic_elo"
                />
        </LinearLayout>

    </androidx.cardview.widget.CardView>

    <ImageButton
        android:id="@+id/btnHistory"
        android:layout_width="0dp"
        android:layout_height="64dp"
        android:contentDescription="@string/history"
        android:src="@drawable/ic_history"
        android:scaleType="centerInside"
        android:padding="2dp"
        app:layout_constraintHorizontal_chainStyle="spread"
        app:layout_constraintHorizontal_weight="1"

        app:layout_constraintTop_toTopOf="@id/btnPlay"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btnPlay"
        app:layout_constraintBottom_toBottomOf="@id/btnPlay"
        />

    <Button
        android:id="@+id/btnPlay"
        android:layout_width="0dp"
        android:layout_height="64dp"
        android:text="@string/play"
        app:layout_constraintHorizontal_weight="2"

        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        app:layout_constraintStart_toEndOf="@id/btnHistory"
        app:layout_constraintTop_toBottomOf="@id/boardSelection"
        app:layout_constraintEnd_toStartOf="@id/btnTrofy"
        app:layout_constraintBottom_toBottomOf="parent"
        />

    <ImageButton
        android:id="@+id/btnTrofy"
        android:layout_width="0dp"
        android:layout_height="64dp"
        android:contentDescription="@string/ranked"
        android:src="@drawable/ic_ranked"
        android:scaleType="centerInside"
        android:padding="2dp"
        app:layout_constraintHorizontal_weight="1"

        app:layout_constraintStart_toEndOf="@id/btnPlay"
        app:layout_constraintTop_toTopOf="@id/btnPlay"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="@id/btnPlay"
        />

</androidx.constraintlayout.widget.ConstraintLayout>