<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardRankingEntry"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardBackgroundColor="@color/S3"
    app:cardCornerRadius="14dp"
    app:cardElevation="0dp"
    app:strokeColor="@color/S2"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="12dp"
        android:paddingVertical="12dp">

        <!-- Posición -->
        <TextView
            android:id="@+id/textRankingPosition"
            android:layout_width="48dp"
            android:layout_height="wrap_content"
            android:text="#1"
            android:textColor="@color/LCWhite"
            android:textSize="15sp"
            android:textStyle="bold"
            android:gravity="center" />

        <!-- Avatar -->
        <ImageView
            android:id="@+id/imageRankingAvatar"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="8dp"
            android:src="@drawable/ic_avatar"
            android:contentDescription="@string/avatar" />

        <!-- Username -->
        <TextView
            android:id="@+id/textRankingUsername"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Usuario"
            android:textColor="@color/LCWhite"
            android:textSize="15sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end" />

        <!-- Elo -->
        <TextView
            android:id="@+id/textRankingElo"
            android:layout_width="72dp"
            android:layout_height="wrap_content"
            android:text="1500"
            android:textColor="@color/LCWhite"
            android:textSize="15sp"
            android:textStyle="bold"
            android:gravity="center" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>