<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Configura el tiempo"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Modo de tiempo" />

        <Spinner
            android:id="@+id/spinnerTimeMode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Incremento" />

        <Spinner
            android:id="@+id/spinnerIncrement"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp" />

        <CheckBox
            android:id="@+id/checkboxCustomConfig"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Configuración personalizada" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tiempo base (minutos, máx. 180)"
            android:layout_marginTop="12dp" />

        <EditText
            android:id="@+id/editCustomTimeMinutes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:enabled="false"
            android:inputType="number" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Incremento (segundos, máx. 60)"
            android:layout_marginTop="12dp" />

        <EditText
            android:id="@+id/editCustomIncrementSeconds"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:enabled="false"
            android:inputType="number" />

    </LinearLayout>
</ScrollView>