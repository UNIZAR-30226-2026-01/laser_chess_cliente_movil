<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:backgroundTint="@color/S3"
    android:clickable="true"
    android:focusable="true"
    android:layout_marginBottom="16dp"
    app:cardCornerRadius="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="8dp">

        <ImageView
            android:id="@+id/imgFriendAvatar"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_avatar"
            android:contentDescription="@string/avatar"
            app:tint="@color/LCWhite"/>

        <TextView
            android:id="@+id/txtFriendUsername"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:text="Usuario 1"
            android:textSize="@dimen/text_medium"
            android:textStyle="bold"
            android:textColor="@color/LCWhite"/>


        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="LVL"
            android:textSize="@dimen/text_medium"
            android:textColor="@color/LCGreen"
            android:layout_marginEnd="8dp"/>

        <TextView
            android:id="@+id/txtFriendLevel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1234"
            android:textSize="@dimen/text_medium"
            android:textColor="@color/LCWhite"
            android:layout_marginEnd="8dp"/>


    </LinearLayout>

</androidx.cardview.widget.CardView>