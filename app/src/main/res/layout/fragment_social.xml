<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:paddingHorizontal="16dp"
    android:paddingTop="20dp"
    android:paddingBottom="20dp">

    <View
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@color/S1"
        app:layout_constraintTop_toBottomOf="@id/layoutTabs"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"/>

    <!-- Tabs / Pestañas -->
    <LinearLayout
        android:id="@+id/layoutTabs"
        android:layout_width="0dp"
        android:layout_height="50dp"
        android:orientation="horizontal"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!--Perstaña de Social -->
        <LinearLayout
            android:id="@+id/tabFriends"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="@color/S2"
            app:layout_constraintStart_toStartOf="parent">

            <TextView
                android:id="@+id/txtTabFriends"
                android:layout_width="wrap_content"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="AMIGOS"
                android:textColor="@color/selector_tab_text_color"
                android:textSize="@dimen/text_medium"
                android:textStyle="bold" />

            <View
                android:id="@+id/indicatorFriends"
                android:layout_width="match_parent"
                android:layout_height="4dp"
                android:background="@color/LCRed"
                android:visibility="gone"/>
        </LinearLayout>

        <!--Pestaña de Partidas -->
        <LinearLayout
            android:id="@+id/tabPartidas"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="@color/S2">

            <TextView
                android:id="@+id/txtTabMatches"
                android:layout_width="wrap_content"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="PARTIDAS"
                android:textColor="@color/selector_tab_text_color"
                android:textSize="@dimen/text_medium"
                android:textStyle="bold" />

            <View
                android:id="@+id/indicatorMatches"
                android:layout_width="match_parent"
                android:layout_height="4dp"
                android:visibility="gone"
                android:background="@color/LCRed" />
        </LinearLayout>
    </LinearLayout>

    <!-- Contenido de SOCIAL -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layoutSocialContent"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        app:layout_constraintTop_toBottomOf="@id/layoutTabs"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" >

        <!-- Sin amigos -->
        <TextView
            android:id="@+id/emptyMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/empty_friends_message"
            android:textColor="@color/LCWhite"
            android:textAlignment="center"
            android:textSize="@dimen/text_medium"
            android:visibility="gone"
            android:layout_margin="16dp"
            android:background="@drawable/bg_dark_pill_panel"
            app:layout_constraintTop_toTopOf="parent"/>

        <!-- Friends List -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerFriends"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_margin="16dp"
            android:paddingBottom="96dp"
            app:layout_constraintTop_toTopOf="parent"/>

        <!-- Solicitudes -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/buttonSolicitudes"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:padding="8dp"
            android:background="@drawable/bg_button"
            android:layout_marginBottom="16dp"
            android:layout_marginStart="16dp"
            android:clipToPadding="false"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <ImageView
                android:id="@+id/iconSolicitudes"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="@string/avatar"
                android:src="@drawable/ic_inbox"
                app:tint="@color/LCWhite"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"/>
            <TextView
                android:id="@+id/txtNumSolicitudes"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:background="@drawable/bg_red_circle"
                android:text="3"
                android:visibility="visible"
                android:textColor="@color/LCWhite"
                android:textSize="@dimen/text_medium_small"
                android:textStyle="bold"
                android:gravity="center"

                app:layout_constraintTop_toTopOf="@+id/iconSolicitudes"
                app:layout_constraintEnd_toEndOf="@+id/iconSolicitudes"

                android:translationX="5dp"
                android:translationY="-5dp" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Botón añadir amigo -->
        <LinearLayout
            android:id="@+id/buttonAddFriend"
            android:layout_width="250dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="16dp"
            android:orientation="horizontal"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <Button
                android:id="@+id/btnAddFriend"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:backgroundTint="@color/LCRed"
                android:insetLeft="0dp"
                android:insetTop="0dp"
                android:insetRight="0dp"
                android:insetBottom="0dp"
                android:text="AGREGAR"
                android:letterSpacing="0"

                android:textColor="@color/LCWhite"
                android:textSize="@dimen/text_medium"
                android:textStyle="bold"
                app:cornerRadius="12dp"
                app:icon="@drawable/ic_add_circle"

                app:iconGravity="textStart"
                app:iconPadding="2dp"
                app:iconSize="24dp"
                app:iconTint="@color/LCWhite" />
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Contenido de IN PROGRESS -->
    <LinearLayout
        android:id="@+id/layoutInProgressContent"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:visibility="gone"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/layoutTabs"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" >

        <!-- Sin partidas -->
        <TextView
            android:id="@+id/emptyInProgressMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="No tienes partidas pausadas"
            android:textSize="@dimen/text_medium"
            android:visibility="gone"
            android:layout_marginTop="16dp" />

        <!-- Lista de partidas en curso -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerInProgressGames"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:paddingBottom="24dp" />

    </LinearLayout>



</androidx.constraintlayout.widget.ConstraintLayout>