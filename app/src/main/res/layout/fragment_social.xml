<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:paddingStart="16dp"
    android:paddingEnd="16dp"
    android:paddingTop="12dp"
    android:paddingBottom="12dp">

    <!-- Tabs / Pestañas -->
    <LinearLayout
        android:id="@+id/layoutTabs"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Pestaña Social -->
        <TextView
            android:id="@+id/tabSocial"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:paddingVertical="12dp"
            android:text="SOCIAL"
            android:textSize="20sp"
            android:textStyle="bold"
            android:background="@drawable/bg_tab_selected" />

        <!-- Pestaña Games In Progress -->
        <TextView
            android:id="@+id/tabInProgress"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:paddingVertical="12dp"
            android:text="IN PROGRESS"
            android:textSize="20sp"
            android:textStyle="bold"
            android:background="@drawable/bg_tab_unselected" />
    </LinearLayout>

    <!-- Contenido de SOCIAL -->
    <LinearLayout
        android:id="@+id/layoutSocialContent"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/layoutTabs"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" >

        <!-- Solicitudes -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardSolicitudes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="0dp"
            app:cardElevation="0dp" >

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="12dp">

                <ImageView
                    android:id="@+id/iconSolicitudes"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:contentDescription="@string/avatar"
                    android:src="@drawable/ic_clock" />

                <TextView
                    android:id="@+id/txtSolicitudes"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:text="Solicitudes"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/txtNumSolicitudes"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <ImageView
                    android:id="@+id/iconArrow"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_marginStart="8dp"
                    android:contentDescription="Ver solicitudes"
                    android:src="@drawable/ic_arrow_right" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Sin amigos -->
        <TextView
            android:id="@+id/emptyMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/empty_friends_message"
            android:textAlignment="center"
            android:textSize="16sp"
            android:visibility="gone"
            android:layout_marginTop="16dp" />

        <!-- Friends List -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerFriends"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginTop="24dp"
            android:paddingBottom="96dp" />

    </LinearLayout>

    <!-- Contenido de IN PROGRESS -->
    <LinearLayout
        android:id="@+id/layoutInProgressContent"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:visibility="gone"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/layoutTabs"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" >

        <!-- Sin partidas -->
        <TextView
            android:id="@+id/emptyInProgressMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="No tienes partidas pausadas"
            android:textSize="16sp"
            android:visibility="gone"
            android:layout_marginTop="16dp" />

        <!-- Lista de partidas en curso -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerInProgressGames"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginTop="16dp"
            android:paddingBottom="24dp" />

    </LinearLayout>

    <!-- Botón añadir amigo -->
    <ImageButton
        android:id="@+id/btnAddFriend"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:layout_margin="20dp"
        android:contentDescription="Añadir amigo"
        android:padding="14dp"
        android:src="@drawable/ic_add_circle"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>