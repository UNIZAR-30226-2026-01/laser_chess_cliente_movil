<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/S1"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_margin="16dp">

    <!-- Tabs / Pestañas -->
    <LinearLayout
        android:id="@+id/layoutTabs"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:background="@drawable/bg_dark_panel"
        android:orientation="horizontal"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!--Perstaña de Social -->
        <LinearLayout
            android:id="@+id/tabSocial"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="@drawable/bg_tab_selected"
            app:layout_constraintStart_toStartOf="parent">

            <TextView
                android:id="@+id/txtTabSocial"
                android:layout_width="wrap_content"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="SOCIAL"
                android:textColor="@color/LCRed"
                android:textSize="@dimen/text_large"
                android:textStyle="bold" />

            <View
                android:id="@+id/indicatorSocial"
                android:layout_width="match_parent"
                android:layout_height="4dp"
                android:background="@color/LCRed" />
        </LinearLayout>

        <!--Pestaña de Partidas -->
        <LinearLayout
            android:id="@+id/tabPartidas"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="@drawable/bg_tab_unselected">

            <TextView
                android:id="@+id/txtTabMatches"
                android:layout_width="wrap_content"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="PARTIDAS"
                android:textColor="@color/S3"
                android:textSize="@dimen/text_large"
                android:textStyle="bold" />

            <View
                android:id="@+id/indicatorMatches"
                android:layout_width="match_parent"
                android:layout_height="4dp"
                android:background="@android:color/transparent" />
        </LinearLayout>
    </LinearLayout>

    <!-- Contenido de SOCIAL -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layoutSocialContent"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/layoutTabs"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" >

        <!-- Sin amigos -->
        <TextView
            android:id="@+id/emptyMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/empty_friends_message"
            android:textAlignment="center"
            android:textSize="@dimen/text_medium"
            android:visibility="gone"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toTopOf="parent"/>

        <!-- Friends List -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerFriends"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginTop="24dp"
            android:paddingBottom="96dp"
            app:layout_constraintTop_toTopOf="parent"/>

        <!-- Solicitudes -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:padding="12dp"
            android:background="@drawable/bg_button"
            android:layout_marginBottom="16dp"
            android:layout_marginStart="16dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <ImageView
                android:id="@+id/iconSolicitudes"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:contentDescription="@string/avatar"
                android:src="@drawable/ic_inbox"
                app:tint="@color/LCRed"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"/>
        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Botón añadir amigo -->
        <LinearLayout
            android:id="@+id/groupSocialButtons"
            android:layout_width="250dp"
            android:layout_height="wrap_content"
            android:layout_margin="14dp"
            android:orientation="horizontal"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <Button
                android:id="@+id/btnAddFriend"
                android:layout_width="0dp"
                android:layout_height="64dp"
                android:layout_weight="1"
                android:backgroundTint="#FF0044"
                android:text="+  AÑADIR"
                android:textColor="@color/LCWhite"
                android:textSize="@dimen/text_large"
                android:textStyle="bold"
                app:cornerRadius="12dp" />
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Contenido de IN PROGRESS -->
    <LinearLayout
        android:id="@+id/layoutInProgressContent"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:visibility="gone"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/layoutTabs"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" >

        <!-- Sin partidas -->
        <TextView
            android:id="@+id/emptyInProgressMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="No tienes partidas pausadas"
            android:textSize="16sp"
            android:visibility="gone"
            android:layout_marginTop="16dp" />

        <!-- Lista de partidas en curso -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerInProgressGames"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginTop="16dp"
            android:paddingBottom="24dp" />

    </LinearLayout>



</androidx.constraintlayout.widget.ConstraintLayout>