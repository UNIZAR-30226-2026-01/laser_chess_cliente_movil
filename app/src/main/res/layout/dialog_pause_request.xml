<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"

    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@android:color/transparent">

    <LinearLayout
        android:id="@+id/container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingVertical="10dp"
        android:background="@drawable/bg_pause_dialog"
        android:elevation="10dp"

        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="60dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- TEXTO -->
        <TextView
            android:id="@+id/textPauseRequest"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tu rival quiere pausar partida"
            android:textStyle="bold"
            android:textSize="14sp"
            android:layout_marginEnd="12dp"
            android:gravity="center_vertical"/>

        <!-- ACEPTAR -->
        <ImageButton
            android:id="@+id/btnAcceptPause"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:padding="8dp"
            android:scaleType="centerInside"
            android:src="@drawable/outline_check_24"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Aceptar"/>

        <!-- RECHAZAR -->
        <ImageButton
            android:id="@+id/btnRejectPause"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:padding="8dp"
            android:scaleType="centerInside"
            android:src="@drawable/baseline_close_24"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Rechazar"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>